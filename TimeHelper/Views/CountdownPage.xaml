<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TimeHelper.Views.CountdownPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:TimeHelper.Models"
    Title="Timer">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <Label
                Style="{StaticResource PageHeadingStyle}"
                Text="Focus Timer" />

            <Label
                Style="{StaticResource MutedLabelStyle}"
                HorizontalTextAlignment="Center"
                Text="Build a session, save a plan, and let the timer handle the rest." />

            <Border Padding="28">
                <VerticalStackLayout Spacing="18">

                    <Label
                        Style="{StaticResource MutedLabelStyle}"
                        HorizontalTextAlignment="Center"
                        Text="CURRENT CLOCK" />

                    <Label
                        x:Name="TimerLabel"
                        Style="{StaticResource ClockStyle}"
                        Text="00:00" />

                    <Label
                        x:Name="StatusLabel"
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource MutedLabelStyle}"
                        Text="Status: Ready" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <Button
                            x:Name="StartButton"
                            Grid.Column="0"
                            Text="Start"
                            Clicked="OnStartClicked" />
                        <Button
                            x:Name="PauseButton"
                            Grid.Column="1"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Text="Pause"
                            Clicked="OnPauseClicked" />
                        <Button
                            x:Name="ResetButton"
                            Grid.Column="2"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Text="Reset"
                            Clicked="OnResetClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Padding="24">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Set Countdown" />

                    <Label
                        Style="{StaticResource MutedLabelStyle}"
                        Text="Length in minutes" />

                    <Entry
                        x:Name="MinutesEntry"
                        Keyboard="Numeric"
                        Placeholder="Enter minutes" />

                    <Label
                        x:Name="AlarmPathLabel"
                        Style="{StaticResource MutedLabelStyle}"
                        Text="Alarm: Default vibration only" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="24">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Save Current Plan" />

                    <Entry
                        x:Name="PlanNameEntry"
                        Placeholder="Example: Deep Work 25" />

                    <Button
                        Text="Save Plan"
                        Clicked="OnSavePlanClicked" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="24">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Saved Plans" />

                    <CollectionView
                        x:Name="PlansCollectionView"
                        SelectionMode="None">

                        <CollectionView.EmptyView>
                            <Label
                                HorizontalTextAlignment="Center"
                                Style="{StaticResource MutedLabelStyle}"
                                Text="No saved plans yet." />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:CountdownPlan">
                                <Border Padding="18" Margin="0,0,0,12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontFamily="OpenSansSemibold"
                                                FontSize="17"
                                                Text="{Binding Name}" />
                                            <Label
                                                Style="{StaticResource MutedLabelStyle}"
                                                Text="{Binding Minutes, StringFormat='Duration: {0} min'}" />
                                        </VerticalStackLayout>

                                        <Button
                                            Grid.Column="1"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Text="Use"
                                            Clicked="OnUsePlanClicked"
                                            CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
