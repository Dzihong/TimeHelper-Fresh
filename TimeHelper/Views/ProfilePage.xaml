<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TimeHelper.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    Title="用户"
    BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Label
                Text="时间助手"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="Black"
                HorizontalOptions="Center" />

            <Label
                Text="用户设置"
                FontSize="20"
                TextColor="Black"
                HorizontalOptions="Center" />

            <Border
                Stroke="Gray"
                StrokeThickness="1"
                BackgroundColor="White"
                Padding="20">
                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="头像设置"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="Black" />

                    <Image
                        x:Name="AvatarImage"
                        Source="dotnet_bot.png"
                        HeightRequest="100"
                        WidthRequest="100"
                        HorizontalOptions="Center" />

                    <Button
                        Text="选择头像（下一步实现）"
                        Clicked="OnChooseAvatarClicked" />
                </VerticalStackLayout>
            </Border>

            <Border
                Stroke="Gray"
                StrokeThickness="1"
                BackgroundColor="White"
                Padding="20">
                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="用户信息"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="Black" />

                    <Label
                        Text="用户名"
                        TextColor="Black" />

                    <Entry
                        x:Name="UserNameEntry"
                        Placeholder="请输入用户名"
                        TextColor="Black"
                        BackgroundColor="White" />

                    <Label
                        Text="当前生活目标"
                        TextColor="Black" />

                    <Editor
                        x:Name="LifeGoalEditor"
                        Placeholder="请输入你当前的生活目标"
                        TextColor="Black"
                        BackgroundColor="White"
                        AutoSize="TextChanges"
                        HeightRequest="120" />
                </VerticalStackLayout>
            </Border>

            <Border
                Stroke="Gray"
                StrokeThickness="1"
                BackgroundColor="White"
                Padding="20">
                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="应用风格"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="Black" />

                    <Picker
                        x:Name="ThemePicker"
                        Title="请选择主题"
                        HeightRequest="50"
                        BackgroundColor="White"
                        SelectedIndexChanged="OnThemeChanged">
                        <Picker.Items>
                            <sys:String>PureBlack</sys:String>
                            <sys:String>PureWhite</sys:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <Border
                Stroke="Gray"
                StrokeThickness="1"
                BackgroundColor="White"
                Padding="20">
                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="倒计时结束音乐"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="Black" />

                    <Label
                        x:Name="MusicPathLabel"
                        Text="当前未选择本地音乐"
                        TextColor="Black" />

                    <Button
                        Text="导入本地音乐（下一步实现）"
                        Clicked="OnChooseMusicClicked" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="保存用户设置"
                Clicked="OnSaveProfileClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>