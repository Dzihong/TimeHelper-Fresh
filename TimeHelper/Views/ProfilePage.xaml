<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TimeHelper.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    Title="Profile">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <Label
                Style="{StaticResource PageHeadingStyle}"
                Text="Profile &amp; Theme" />

            <Label
                Style="{StaticResource MutedLabelStyle}"
                HorizontalTextAlignment="Center"
                Text="Keep your profile tidy, choose the visual mode, and set your own MP3 alarm." />

            <Border Padding="24">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Avatar" />

                    <Image
                        x:Name="AvatarImage"
                        Source="dotnet_bot.png"
                        HeightRequest="104"
                        WidthRequest="104"
                        HorizontalOptions="Center" />

                    <Label
                        x:Name="AvatarPathLabel"
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource MutedLabelStyle}"
                        Text="No avatar selected" />

                    <Button
                        Style="{StaticResource SecondaryButtonStyle}"
                        Text="Choose Avatar"
                        Clicked="OnChooseAvatarClicked" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="24">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Profile Details" />

                    <Label
                        Style="{StaticResource MutedLabelStyle}"
                        Text="User name" />

                    <Entry
                        x:Name="UserNameEntry"
                        Placeholder="Enter your name" />

                    <Label
                        Style="{StaticResource MutedLabelStyle}"
                        Text="Current life goal" />

                    <Editor
                        x:Name="LifeGoalEditor"
                        AutoSize="TextChanges"
                        HeightRequest="120"
                        Placeholder="Write your current focus or goal" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="24">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Theme Mode" />

                    <Picker
                        x:Name="ThemePicker"
                        Title="Choose a mode"
                        SelectedIndexChanged="OnThemeChanged">
                        <Picker.Items>
                            <sys:String>PureWhite</sys:String>
                            <sys:String>PureBlack</sys:String>
                        </Picker.Items>
                    </Picker>

                    <Label
                        Style="{StaticResource MutedLabelStyle}"
                        Text="Dark mode keeps every large surface in layered grey while text turns white for contrast." />
                </VerticalStackLayout>
            </Border>

            <Border Padding="24">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Alarm Sound" />

                    <Label
                        x:Name="MusicPathLabel"
                        Style="{StaticResource MutedLabelStyle}"
                        Text="No MP3 alarm selected" />

                    <Button
                        Style="{StaticResource SecondaryButtonStyle}"
                        Text="Choose MP3 Alarm"
                        Clicked="OnChooseMusicClicked" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="24">
                <VerticalStackLayout Spacing="14">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Timer Alerts" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontFamily="OpenSansSemibold"
                                Text="Vibration" />
                            <Label
                                Style="{StaticResource MutedLabelStyle}"
                                Text="Vibrate when the countdown ends." />
                        </VerticalStackLayout>

                        <Switch
                            x:Name="VibrationSwitch"
                            Grid.Column="1"
                            IsToggled="True" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontFamily="OpenSansSemibold"
                                Text="Flashlight" />
                            <Label
                                Style="{StaticResource MutedLabelStyle}"
                                Text="Flash briefly when the device supports it." />
                        </VerticalStackLayout>

                        <Switch
                            x:Name="FlashSwitch"
                            Grid.Column="1"
                            IsToggled="True" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Save Profile"
                Clicked="OnSaveProfileClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
