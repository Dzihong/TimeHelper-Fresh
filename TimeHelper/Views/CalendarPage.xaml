<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TimeHelper.Views.CalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Calendar">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <Label
                Style="{StaticResource PageHeadingStyle}"
                Text="Focus Calendar" />

            <Label
                Style="{StaticResource MutedLabelStyle}"
                HorizontalTextAlignment="Center"
                Text="See your month at a glance and tap any day for a quick session breakdown." />

            <Border Padding="24">
                <VerticalStackLayout Spacing="16">

                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                        <Button
                            Style="{StaticResource SecondaryButtonStyle}"
                            Text="&lt;"
                            Clicked="OnPreviousMonthClicked" />

                        <Label
                            x:Name="MonthLabel"
                            Grid.Column="1"
                            FontFamily="OpenSansSemibold"
                            FontSize="22"
                            HorizontalTextAlignment="Center"
                            Text="April 2026" />

                        <Button
                            Grid.Column="2"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Text="&gt;"
                            Clicked="OnNextMonthClicked" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" Padding="18">
                            <VerticalStackLayout Spacing="6">
                                <Label
                                    Style="{StaticResource MutedLabelStyle}"
                                    Text="THIS MONTH" />
                                <Label
                                    x:Name="TotalCountLabel"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="28"
                                    Text="0 sessions" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" Padding="18">
                            <VerticalStackLayout Spacing="6">
                                <Label
                                    Style="{StaticResource MutedLabelStyle}"
                                    Text="TOTAL MINUTES" />
                                <Label
                                    x:Name="TotalMinutesLabel"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="28"
                                    Text="0 min" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="8">
                        <Label Grid.Column="0" HorizontalTextAlignment="Center" Style="{StaticResource MutedLabelStyle}" Text="Sun" />
                        <Label Grid.Column="1" HorizontalTextAlignment="Center" Style="{StaticResource MutedLabelStyle}" Text="Mon" />
                        <Label Grid.Column="2" HorizontalTextAlignment="Center" Style="{StaticResource MutedLabelStyle}" Text="Tue" />
                        <Label Grid.Column="3" HorizontalTextAlignment="Center" Style="{StaticResource MutedLabelStyle}" Text="Wed" />
                        <Label Grid.Column="4" HorizontalTextAlignment="Center" Style="{StaticResource MutedLabelStyle}" Text="Thu" />
                        <Label Grid.Column="5" HorizontalTextAlignment="Center" Style="{StaticResource MutedLabelStyle}" Text="Fri" />
                        <Label Grid.Column="6" HorizontalTextAlignment="Center" Style="{StaticResource MutedLabelStyle}" Text="Sat" />
                    </Grid>

                    <Grid
                        x:Name="CalendarGrid"
                        ColumnDefinitions="*,*,*,*,*,*,*"
                        ColumnSpacing="8"
                        RowSpacing="8" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="24">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Selected Day" />
                    <Label
                        x:Name="SelectedDayLabel"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        Text="Tap a day" />
                    <Label
                        x:Name="SelectedDaySummaryLabel"
                        Style="{StaticResource MutedLabelStyle}"
                        Text="Choose a date in the calendar to inspect its countdown usage." />
                </VerticalStackLayout>
            </Border>

            <Border Padding="24">
                <VerticalStackLayout Spacing="12">
                    <Label
                        Style="{StaticResource SectionHeadingStyle}"
                        Text="Plan Files" />

                    <Button
                        Text="Export Plans JSON"
                        Clicked="OnExportPlansClicked" />

                    <Button
                        Style="{StaticResource SecondaryButtonStyle}"
                        Text="Import Plans JSON"
                        Clicked="OnImportPlansClicked" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
