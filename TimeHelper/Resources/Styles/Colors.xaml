<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="PageLight">#F4F6F8</Color>
    <Color x:Key="PageDark">#202124</Color>

    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#2B2D31</Color>

    <Color x:Key="RaisedLight">#EEF3F5</Color>
    <Color x:Key="RaisedDark">#32353A</Color>

    <Color x:Key="PanelLight">#E7ECEF</Color>
